# Required — regular project API key (the "victim" key)
OPENAI_API_KEY=sk-proj-...

# Required for phases 3 & 5 (create/delete API keys via Management API)
# Create an Admin Key at: https://platform.openai.com/api-keys
# (needs "Manage API keys" permission)
OPENAI_ADMIN_KEY=sk-admin-...

# Optional — your organization ID (found in platform.openai.com/settings)
OPENAI_ORG_ID=org-...

# Simulation tuning (optional — these are the defaults)
PHASE_DELAY_SECONDS=3       # seconds to pause between phases
BASELINE_REQUESTS=10        # number of normal completions in phase 1
